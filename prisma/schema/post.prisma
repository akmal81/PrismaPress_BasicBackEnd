model Post {
    id         String   @id @default(uuid())
    title      String   @db.VarChar(255)
    content    String
    thumbnail  String?
    isFeatured Boolean  @default(false)
    tags       String[]
    views      Int
    
    authorId   String
    user       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

    comments Comments[]

    createdAt  DateTime
    updatedAt  DateTime
}
